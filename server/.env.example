# Copy to .env and fill in real values for production.

# Server
PORT=5000
NODE_ENV=development

# MongoDB — leave unset in development to use an in-memory database.
# MONGODB_URI=mongodb://localhost:27017/aas-leathers

# Frontend origin allowed for CORS (credentials)
CLIENT_URL=http://localhost:3000

# JWT — generate long random strings for production, e.g. `openssl rand -hex 64`
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Email — leave all unset in development to log emails instead of sending.
# Option A (friendliest): discrete SMTP settings, e.g. Gmail with an App Password.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   MAIL_FROM=AAS Leathers <you@gmail.com>
# Option B: a single connection URL (encode @ in the username as %40).
#   SMTP_URL=smtps://you%40gmail.com:app-password@smtp.gmail.com:465

# Razorpay — leave unset to fall back to a mock/pending checkout.
# Get TEST keys from the Razorpay dashboard (Test Mode) -> Settings -> API Keys.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=optional-webhook-secret
