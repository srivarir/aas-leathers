# ─────────────────────────────────────────────────────────────
# AAS Leathers — ignore secrets, dependencies, and build output
# ─────────────────────────────────────────────────────────────

# Secrets / environment — NEVER commit these
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Dependencies
node_modules/
**/node_modules/

# Next.js build output
web/.next/
web/out/
web/next-env.d.ts
web/.turbo/

# Server runtime
server/uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Stale/large deploy artifacts (regenerated as needed)
deploy-kit/*.zip

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
